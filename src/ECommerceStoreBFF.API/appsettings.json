{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Debug"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "products-swagger-route": {
        "ClusterId": "products-cluster",
        "Match": { "Path": "/api/products/swagger/v1/swagger.json" },
        "Transforms": [ { "PathRemovePrefix": "/api/products" } ]
      },
      "users-swagger-route": {
        "ClusterId": "users-cluster",
        "Match": { "Path": "/api/users/swagger/v1/swagger.json" },
        "Transforms": [ { "PathRemovePrefix": "/api/users" } ]
      },
      "orders-swagger-route": {
        "ClusterId": "orders-cluster",
        "Match": { "Path": "/api/orders/swagger/v1/swagger.json" },
        "Transforms": [ { "PathRemovePrefix": "/api/orders" } ]
      },

      "products-route": {
        "ClusterId": "products-cluster",
        "Match": {
          "Path": "/{**catchall:regex(mobile-phones|categories|currencies)}"
        }
      },
      "products-documentation-route": {
        "ClusterId": "products-cluster",
        "Match": { "Path": "/products/{**catchall:regex(documentation)}" },
        "Transforms": [ { "PathRemovePrefix": "/products" } ]
      },

      "users-route": {
        "ClusterId": "users-cluster",
        "Match": {
          "Path": "/{**catchall:regex(users|customers|admins)}"
        }
      },
      "users-documentation-route": {
        "ClusterId": "users-cluster",
        "Match": { "Path": "/users/{**catchall:regex(documentation)}" },
        "Transforms": [ { "PathRemovePrefix": "/users" } ]
      },

      "orders-route": {
        "ClusterId": "orders-cluster",
        "Match": {
          "Path": "/{**catchall:regex(orders|shopping-carts|invoices)}"
        }
      },
      "orders-documentation-route": {
        "ClusterId": "orders-cluster",
        "Match": { "Path": "/orders/{**catchall:regex(documentation)}" },
        "Transforms": [ { "PathRemovePrefix": "/orders" } ]
      }
    },
    "Clusters": {
      "products-cluster": { "Destinations": { "destination1": { "Address": "http://localhost:5000" } } },
      "users-cluster": { "Destinations": { "destination1": { "Address": "http://localhost:6500" } } },
      "orders-cluster": { "Destinations": { "destination1": { "Address": "http://localhost:7000" } } }
    }
  }
}